TRIGGER_PROJECT_REF=proj_model_atlas
TRIGGER_SECRET_KEY=tr_dev_or_prod_xxx
# Optional for local/CI Trigger deploy auth. Export in shell before deploy.
# TRIGGER_ACCESS_TOKEN=tr_pat_xxx

# Feishu Bitable source of truth.
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_BITABLE_APP_TOKEN=bascnxxx
FEISHU_MODELS_TABLE_ID=tblxxx
FEISHU_CASES_TABLE_ID=tblxxx

# Hermes SSH orchestration. Store password/private key as Trigger Secret values.
MODEL_ATLAS_HERMES_SSH_HOST=124.221.3.41
MODEL_ATLAS_HERMES_SSH_USER=ubuntu
MODEL_ATLAS_HERMES_SSH_PORT=22
# MODEL_ATLAS_HERMES_SSH_PASSWORD=...
# MODEL_ATLAS_HERMES_SSH_PRIVATE_KEY=...
MODEL_ATLAS_SSH_TIMEOUT_MS=1800000
MODEL_ATLAS_POLL_TIMEOUT_MS=1200000

# Remote commands expected on the Hermes server.
MODEL_ATLAS_REMOTE_COMMAND=cd /home/ubuntu/.hermes/data/model_atlas_repo/site && bash scripts/model_atlas_auto_pipeline.sh
MODEL_ATLAS_REMOTE_POLL_COMMAND=cd /home/ubuntu/.hermes/data/model_atlas_repo/site && bash scripts/model_atlas_case_poll_once.sh

# Schedules.
MODEL_ATLAS_CRON=0 */6 * * *
MODEL_ATLAS_POLL_CRON=*/30 * * * *
MODEL_ATLAS_TIMEZONE=Asia/Shanghai
