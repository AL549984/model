---
import PublishabilityBadge from "../data/PublishabilityBadge.astro";

const { model, compact = false } = Astro.props;
---

<a href={`/models/${model.slug}`} class="group block rounded-lg border border-slate-700/70 bg-slate-950/45 p-4 transition hover:-translate-y-0.5 hover:border-cyan-300/45 hover:bg-slate-900/70">
  <div class="flex items-start justify-between gap-3">
    <div>
      <p class="text-base font-semibold text-slate-50">{model.name}</p>
      <p class="mt-1 text-sm text-slate-400">{model.vendor}</p>
    </div>
    <PublishabilityBadge status={model.publishability} />
  </div>
  <p class="mt-3 text-sm leading-relaxed text-slate-300">{model.summary}</p>
  {!compact && (
    <div class="mt-4 grid grid-cols-2 gap-2 text-xs text-slate-300">
      <span class="rounded-md border border-slate-700/70 bg-slate-950/40 px-2 py-1">A 类案例：{model.aCaseCount}</span>
      <span class="rounded-md border border-slate-700/70 bg-slate-950/40 px-2 py-1">{model.capabilities.codingAgent}</span>
    </div>
  )}
</a>
