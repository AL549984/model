---
import PublishabilityBadge from "../data/PublishabilityBadge.astro";
import { publicizeText } from "../../lib/publicCopy";

const { model, compact = false } = Astro.props;
const summary = publicizeText(model.summary);
const modelHref = `/models/${model.slug}`;
const compareFallbackId = model.id === "gpt-5-1-high" ? "glm-4-7" : "gpt-5-1-high";
const compareHref = `/compare?models=${[model.id, compareFallbackId].map(encodeURIComponent).join(",")}`;
---

<article class="group flex min-h-full flex-col border border-[#f4f1ea]/20 bg-[#070707] p-5 transition hover:border-[#ff3b4e]/70 hover:bg-[#f4f1ea]/[0.035]">
  <div class="flex items-start justify-between gap-3">
    <div>
      <h3 class="text-lg font-semibold leading-tight text-[#f4f1ea]">
        <a href={modelHref} class="transition hover:text-[#ff3b4e] focus:text-[#ff3b4e] focus:outline-none">{model.name}</a>
      </h3>
      <p class="mono mt-2 text-[11px] uppercase tracking-[0.12em] text-[#a8a29a]">{model.vendor}</p>
    </div>
    <PublishabilityBadge status={model.publishability} />
  </div>
  <p class="mt-5 flex-1 text-sm leading-relaxed text-[#a8a29a]">{summary}</p>
  {!compact && (
    <div class="mt-5 grid grid-cols-2 gap-px bg-[#f4f1ea]/20 text-xs text-[#a8a29a]">
      <span class="bg-[#050505] px-3 py-2">A 类案例：{model.aCaseCount}</span>
      <span class="bg-[#050505] px-3 py-2">{model.capabilities.codingAgent}</span>
    </div>
  )}
  <div class="mt-5 flex flex-wrap gap-2">
    <a href={modelHref} class="mono inline-flex min-h-9 items-center border border-[#f4f1ea]/20 px-3 text-[11px] uppercase tracking-[0.08em] text-[#f4f1ea] transition hover:border-[#ff3b4e]/70 hover:text-[#ff3b4e] focus:border-[#ff3b4e]/70 focus:text-[#ff3b4e] focus:outline-none">模型档案</a>
    <a href={compareHref} class="mono inline-flex min-h-9 items-center border border-[#ff3b4e]/55 bg-[#ff3b4e]/10 px-3 text-[11px] uppercase tracking-[0.08em] text-[#f4f1ea] transition hover:bg-[#ff3b4e]/16 hover:text-[#ff3b4e] focus:text-[#ff3b4e] focus:outline-none" data-model-compare>加入对比</a>
  </div>
</article>
