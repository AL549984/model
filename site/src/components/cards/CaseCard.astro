---
import EvidenceBadge from "../data/EvidenceBadge.astro";
import PublishabilityBadge from "../data/PublishabilityBadge.astro";

const { item } = Astro.props;
const artifactLinks = String(item.artifactUrl ?? "").split(" ; ").filter(Boolean);
const aReason = "有具体使用者、具体任务、公开原始证据和可访问产物，可公开核验。";
const modelHref = `/models/${item.modelId}`;
const vendorHref = `/vendors/${item.vendorId}`;
---

<article class="rounded-lg border border-slate-700/70 bg-slate-950/45 p-4">
  <div class="flex items-start justify-between gap-3">
    <div>
      <p class="text-base font-semibold text-slate-50">{item.title}</p>
      <p class="mt-1 text-sm text-slate-400">
        {item.userOrOrg} · <a class="text-cyan-100 hover:text-cyan-200" href={modelHref}>{item.modelName}</a>
      </p>
    </div>
    <EvidenceBadge grade={item.evidenceGrade} />
  </div>

  <div class="mt-4 grid gap-2 text-xs text-slate-300 sm:grid-cols-2">
    <a class="rounded-md border border-slate-700/70 px-2 py-1 text-cyan-100 hover:border-cyan-300/40" href={vendorHref}>厂商：{item.vendor}</a>
    <a class="rounded-md border border-slate-700/70 px-2 py-1 text-cyan-100 hover:border-cyan-300/40" href={modelHref}>模型：{item.modelName}</a>
    <span class="rounded-md border border-slate-700/70 px-2 py-1">来源平台：{item.sourcePlatform}</span>
    <span class="rounded-md border border-slate-700/70 px-2 py-1">来源类型：{item.sourceType}</span>
    <span class="rounded-md border border-slate-700/70 px-2 py-1">审核状态：{item.reviewStatus}</span>
    <span class="rounded-md border border-slate-700/70 px-2 py-1">最后复核：{item.collectedAt}</span>
  </div>

  <div class="mt-4 space-y-3 text-sm leading-relaxed text-slate-300">
    <p><span class="font-semibold text-slate-100">任务：</span>{item.taskDescription}</p>
    <p><span class="font-semibold text-slate-100">输出：</span>{item.outputResult}</p>
    <p><span class="font-semibold text-slate-100">模型发挥点：</span>{item.modelContribution}</p>
    <p><span class="font-semibold text-slate-100">为什么算 A 类：</span>{aReason}</p>
    <p class="text-slate-400"><span class="font-semibold text-slate-300">风险备注：</span>{item.riskNotes}</p>
  </div>

  <div class="mt-4 flex flex-wrap gap-2 text-xs">
    <PublishabilityBadge status={item.showcaseEligible ? "Publishable" : "Limited"} />
    <span class="rounded-md border border-slate-700/70 px-2 py-1 text-slate-300">{item.taskCategory}</span>
    <span class="rounded-md border border-slate-700/70 px-2 py-1 text-slate-300">{item.reviewStatus}</span>
    {item.selectedForModelCard && <span class="rounded-md border border-cyan-300/30 px-2 py-1 text-cyan-100">进入模型卡精选</span>}
  </div>
  <div class="mt-4 grid gap-2 text-sm md:grid-cols-2">
    <a class="link-accent truncate" href={item.originalEvidenceUrl} target="_blank" rel="noreferrer">原始证据</a>
    {artifactLinks.map((link) => (
      <a class="link-accent truncate" href={link} target="_blank" rel="noreferrer">产物链接</a>
    ))}
  </div>
</article>
