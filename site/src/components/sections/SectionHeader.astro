---
const { eyebrow, title, description } = Astro.props;
---

<header class="mb-4">
  {eyebrow && <p class="mono text-xs uppercase tracking-[0.16em] text-cyan-200">{eyebrow}</p>}
  <h2 class="mt-2 text-2xl font-semibold text-slate-50 md:text-3xl">{title}</h2>
  {description && <p class="mt-2 max-w-3xl text-sm leading-relaxed text-slate-400">{description}</p>}
</header>
