---
const { eyebrow, title, description } = Astro.props;
---

<header class="mb-4">
  {eyebrow && <p class="mono text-xs uppercase tracking-[0.16em] text-[#ff3b4e]">{eyebrow}</p>}
  <h2 class="mt-2 text-3xl font-black leading-tight tracking-normal text-[#f4f1ea] md:text-5xl">{title}</h2>
  {description && <p class="mt-3 max-w-3xl text-sm leading-relaxed text-[#a8a29a] md:text-base">{description}</p>}
</header>
