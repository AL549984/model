---
import PublishabilityBadge from "./PublishabilityBadge.astro";
import { publicizeText } from "../../lib/publicCopy";

const { model, modelCases: rawModelCases = [] } = Astro.props;
const modelCases = rawModelCases as Array<Record<string, any>>;
const hasAAReference = (model.sources ?? []).some((source: string) => source.includes("artificialanalysis.ai")) || String(model.officialLink ?? "").includes("artificialanalysis.ai");
const hasOfficialReference = (model.sources ?? []).some((source: string) => !source.includes("artificialanalysis.ai")) || (Boolean(model.officialLink) && !String(model.officialLink).includes("artificialanalysis.ai"));
const hasCaseEvidence = modelCases.length > 0;
const evidenceStrength = hasCaseEvidence && model.publishability === "Publishable" ? "强" : hasAAReference || hasOfficialReference ? "待补公开案例" : "待补公开资料";
---

<section class="panel p-4">
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <p class="mono text-xs uppercase tracking-[0.12em] text-slate-300">数据可信度 / 证据强度</p>
      <p class="mt-2 text-2xl font-semibold text-slate-50">{evidenceStrength}</p>
    </div>
    <PublishabilityBadge status={model.publishability} />
  </div>

  <div class="mt-4 grid gap-2 text-sm text-slate-300 sm:grid-cols-2">
    <div class="rounded-md border border-slate-700/70 bg-slate-950/35 p-3">
      <p class="text-slate-400">A 类案例</p>
      <p class="mt-1 font-mono text-lg text-cyan-100">{model.aCaseCount}</p>
    </div>
    <div class="rounded-md border border-slate-700/70 bg-slate-950/35 p-3">
      <p class="text-slate-400">AA 评分</p>
      <p class="mt-1 font-mono text-lg text-slate-100">{typeof model.score === "number" ? model.score : "暂无数据"}</p>
    </div>
    <div class="rounded-md border border-slate-700/70 bg-slate-950/35 p-3">
      <p class="text-slate-400">官方来源</p>
      <p class="mt-1 text-slate-100">{hasOfficialReference ? `${model.supplementalSourceCount ?? 1} 个补充入口` : "官方未披露 / 待核验"}</p>
    </div>
    <div class="rounded-md border border-slate-700/70 bg-slate-950/35 p-3">
      <p class="text-slate-400">案例来源</p>
      <p class="mt-1 text-slate-100">{hasCaseEvidence ? `${modelCases.length} 条可核验` : "暂无 A 类案例"}</p>
    </div>
  </div>

  <p class="mt-4 text-sm leading-relaxed text-slate-400">{publicizeText(model.sourceStatus)}</p>
</section>
