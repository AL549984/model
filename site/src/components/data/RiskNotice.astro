---
const { title = "风险提示", tone = "limited", notes: rawNotes = [] } = Astro.props;
const notes = rawNotes as string[];
const toneClass =
  tone === "hold"
    ? "border-rose-400/30 bg-rose-500/10"
    : tone === "neutral"
      ? "border-slate-400/25 bg-slate-500/10"
      : "border-amber-300/30 bg-amber-400/10";
---

<aside class={`rounded-lg border p-4 ${toneClass}`}>
  <p class="mono text-xs uppercase tracking-[0.12em] text-slate-300">{title}</p>
  <ul class="mt-3 space-y-2 text-sm text-slate-200">
    {notes.map((note: string) => <li class="leading-relaxed">- {note}</li>)}
  </ul>
</aside>
