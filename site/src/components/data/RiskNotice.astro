---
import { publicizeText } from "../../lib/publicCopy";

const { title = "风险提示", tone = "limited", notes: rawNotes = [] } = Astro.props;
const notes = rawNotes as string[];
const toneClass =
  tone === "hold"
    ? "border-[#ff3b4e]/45 bg-[#ff3b4e]/[0.06]"
    : tone === "neutral"
      ? "border-[#f4f1ea]/20 bg-[#070707]"
      : "border-[#ff3b4e]/35 bg-[#ff3b4e]/[0.045]";
---

<aside class={`border p-4 ${toneClass}`}>
  <p class="mono text-xs uppercase tracking-[0.12em] text-[#ff3b4e]">{publicizeText(title)}</p>
  <ul class="mt-3 space-y-2 text-sm text-[#a8a29a]">
    {notes.map((note: string) => <li class="leading-relaxed">- {publicizeText(note)}</li>)}
  </ul>
</aside>
