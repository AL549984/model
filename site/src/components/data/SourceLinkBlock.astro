---
const { sources: rawSources = [] } = Astro.props;
const sources = rawSources as string[];
---

<div class="panel p-4">
  <p class="mono text-xs uppercase tracking-[0.12em] text-slate-300">来源和证据</p>
  <div class="mt-3 space-y-2">
    {sources.map((source: string) => (
      <a class="block truncate rounded-md border border-slate-700/70 bg-slate-950/35 px-3 py-2 text-sm text-cyan-100 hover:border-cyan-300/40 hover:text-cyan-200" href={source} target="_blank" rel="noreferrer">
        {source}
      </a>
    ))}
  </div>
</div>
