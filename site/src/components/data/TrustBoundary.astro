---
import { publicizeText } from "../../lib/publicCopy";

const {
  title = "可信边界",
  notes = [
    "A 类案例只收公开可核验的原始证据和产物链接。",
    "暂无案例不代表模型没有能力，只代表尚未找到符合 A 类标准的公开使用案例。",
    "待补公开案例不是不能用，而是公开证据还没有达到推荐标准。"
  ],
  tone = "cyan"
} = Astro.props;

const toneClass = tone === "amber"
  ? "border-[#ff3b4e]/45 bg-[#ff3b4e]/[0.06] text-[#f4f1ea]"
  : "border-[#f4f1ea]/20 bg-[#070707] text-[#f4f1ea]";
---

<aside class={`border p-4 text-sm leading-relaxed ${toneClass}`}>
  <p class="font-semibold text-[#f4f1ea]">{publicizeText(title)}</p>
  <ul class="mt-3 space-y-2 text-[#a8a29a]">
    {notes.map((note: string) => <li>- {publicizeText(note)}</li>)}
  </ul>
</aside>
