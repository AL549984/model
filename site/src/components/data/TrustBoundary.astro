---
const {
  title = "可信边界",
  notes = [
    "A 类案例只收公开可核验的原始证据和产物链接。",
    "暂无案例不代表模型没有能力，只代表尚未找到符合 A 类标准的公开使用案例。",
    "有限证据不是不能用，而是公开证据未达网站发布标准。"
  ],
  tone = "cyan"
} = Astro.props;

const toneClass = tone === "amber"
  ? "border-amber-300/25 bg-amber-300/10 text-amber-50"
  : "border-cyan-300/25 bg-cyan-300/10 text-cyan-50";
---

<aside class={`rounded-lg border p-4 text-sm leading-relaxed ${toneClass}`}>
  <p class="font-semibold text-slate-50">{title}</p>
  <ul class="mt-3 space-y-2">
    {notes.map((note: string) => <li>- {note}</li>)}
  </ul>
</aside>
