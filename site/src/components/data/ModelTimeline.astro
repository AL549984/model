---
import { publicizeText } from "../../lib/publicCopy";

const { items: rawItems = [] } = Astro.props;
const items = rawItems as Array<{ date: string; title: string; summary: string; href?: string }>;
---

<div class="panel p-4">
  <div class="space-y-4">
    {items.map((item) => {
      const content = (
        <>
          <span class="absolute -left-[5px] top-1.5 h-2.5 w-2.5 rounded-full bg-cyan-300"></span>
          <p class="mono text-xs text-cyan-100">{item.date}</p>
          <p class="mt-1 font-semibold text-slate-100">{publicizeText(item.title)}</p>
          <p class="mt-1 text-sm text-slate-400">{publicizeText(item.summary)}</p>
        </>
      );
      return item.href ? (
        <a class="relative block border-l border-cyan-300/20 pl-4 transition hover:border-[#ff3b4e]/70 hover:bg-[#f4f1ea]/5" href={item.href}>
          {content}
        </a>
      ) : (
        <div class="relative border-l border-cyan-300/20 pl-4">
          {content}
        </div>
      );
    })}
  </div>
</div>
