---
import { publicStatusLabel } from "../../lib/publicCopy";

const { status } = Astro.props;

const normalized = String(status ?? "").toLowerCase();
const statusKeys: Record<string, string> = {
  publishable: "Publishable",
  limited: "Limited",
  hold: "Hold",
  archive: "Archive"
};
const label = publicStatusLabel(statusKeys[normalized] ?? String(status ?? "待定"));
const classes =
  normalized === "publishable"
    ? "border-[#ff3b4e]/60 text-[#f4f1ea]"
    : normalized === "limited"
      ? "border-[#f4f1ea]/30 text-[#a8a29a]"
      : "border-[#ff3b4e]/40 text-[#ff3b4e]";
---

<span class={`mono inline-flex items-center gap-1 border bg-transparent px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] ${classes}`}>
  <span class="h-1.5 w-1.5 rounded-full bg-current"></span>
  {label}
</span>
