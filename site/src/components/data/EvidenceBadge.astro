---
const { grade } = Astro.props;

const normalized = String(grade ?? "").toUpperCase();
const classes =
  normalized === "A"
    ? "border-[#ff3b4e]/70 text-[#ff3b4e]"
    : normalized === "B"
      ? "border-[#f4f1ea]/30 text-[#f4f1ea]"
      : normalized === "C"
        ? "border-[#f4f1ea]/25 text-[#a8a29a]"
        : "border-[#ff3b4e]/40 text-[#ff3b4e]";
---

<span class={`inline-flex min-w-8 items-center justify-center border bg-transparent px-2 py-1 font-mono text-xs font-bold ${classes}`}>
  {normalized}
</span>
