---
const { grade } = Astro.props;

const normalized = String(grade ?? "").toUpperCase();
const classes =
  normalized === "A"
    ? "border-emerald-400/50 bg-emerald-400/15 text-emerald-100"
    : normalized === "B"
      ? "border-sky-400/50 bg-sky-400/12 text-sky-100"
      : normalized === "C"
        ? "border-slate-400/40 bg-slate-400/10 text-slate-200"
        : "border-rose-400/45 bg-rose-400/12 text-rose-100";
---

<span class={`inline-flex min-w-8 items-center justify-center rounded-md border px-2 py-1 font-mono text-xs font-bold ${classes}`}>
  {normalized}
</span>
