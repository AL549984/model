---
const { item } = Astro.props;

const priorityLabels: Record<string, string> = {
  P0: "P0",
  P1: "P1",
  P2: "P2",
  P3: "P3"
};
const statusLabels: Record<string, string> = {
  needs_a_case: "待补 A 类案例",
  identity_first: "先确认模型身份",
  snapshot_and_field_refresh: "补快照和字段",
  archive_review: "归档复核"
};
const priorityTone: Record<string, string> = {
  P0: "border-rose-300/35 bg-rose-300/10 text-rose-50",
  P1: "border-amber-300/35 bg-amber-300/10 text-amber-50",
  P2: "border-cyan-300/30 bg-cyan-300/10 text-cyan-100",
  P3: "border-slate-500/40 bg-slate-500/10 text-slate-200"
};
---

{item && (
  <section class="panel p-4">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <p class="mono text-xs uppercase tracking-[0.12em] text-slate-300">补证路线</p>
        <p class="mt-2 text-sm leading-relaxed text-slate-300">{item.blocker}</p>
      </div>
      <div class="flex flex-wrap gap-2">
        <span class:list={["rounded-md border px-2 py-1 text-xs font-semibold", priorityTone[item.priority] ?? priorityTone.P2]}>
          {priorityLabels[item.priority] ?? item.priority}
        </span>
        <span class="rounded-md border border-slate-700/70 bg-slate-950/35 px-2 py-1 text-xs text-slate-200">
          {statusLabels[item.status] ?? item.status}
        </span>
      </div>
    </div>

    <div class="mt-4 grid gap-4 lg:grid-cols-2">
      <div>
        <p class="text-sm font-semibold text-slate-100">需要补齐</p>
        <ul class="mt-2 space-y-2 text-sm text-slate-300">
          {item.requiredEvidence.map((entry: string) => <li>- {entry}</li>)}
        </ul>
      </div>
      <div>
        <p class="text-sm font-semibold text-slate-100">优先来源</p>
        <ul class="mt-2 space-y-2 text-sm text-slate-300">
          {item.targetSources.map((entry: string) => <li>- {entry}</li>)}
        </ul>
      </div>
    </div>

    <div class="mt-4">
      <p class="text-sm font-semibold text-slate-100">搜索入口</p>
      <div class="mt-2 flex flex-wrap gap-2 text-sm">
        {item.searchQueries.map((entry: { query: string; url: string }) => (
          <a class="rounded-md border border-cyan-300/30 px-3 py-2 text-cyan-100 hover:border-cyan-200/60" href={entry.url} target="_blank" rel="noreferrer">
            {entry.query}
          </a>
        ))}
      </div>
    </div>

    <p class="mt-4 text-sm leading-relaxed text-slate-400">{item.upgradeGate}</p>
  </section>
)}
