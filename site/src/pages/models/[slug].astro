---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import SectionHeader from "../../components/sections/SectionHeader.astro";
import CaseCard from "../../components/cards/CaseCard.astro";
import PublishabilityBadge from "../../components/data/PublishabilityBadge.astro";
import RiskNotice from "../../components/data/RiskNotice.astro";
import SourceLinkBlock from "../../components/data/SourceLinkBlock.astro";
import ModelTimeline from "../../components/data/ModelTimeline.astro";
import EvidencePanel from "../../components/data/EvidencePanel.astro";
import EvidenceDistribution from "../../components/data/EvidenceDistribution.astro";
import DataGapPanel from "../../components/data/DataGapPanel.astro";
import { publicStatusLabel, publicizeText } from "../../lib/publicCopy";
import { absoluteUrl, cleanList, httpLinks } from "../../lib/seo";
import { buildEvidenceTrust } from "../../lib/evidenceTrust";
import models from "../../data/models.json";
import cases from "../../data/cases.json";
import evidenceArchive from "../../data/evidence-archive.json";

export function getStaticPaths() {
  return models.map((model) => ({ params: { slug: model.slug }, props: { model } }));
}

const { model } = Astro.props;
const modelCases = cases.filter((item) => item.modelId === model.id && item.evidenceGrade === "A" && item.showcaseEligible);
const evidenceArchiveMap = new Map(evidenceArchive.cases.map((entry) => [entry.caseId, entry]));
const modelArchiveEntries = modelCases.map((item) => evidenceArchiveMap.get(item.id)).filter(Boolean);
const snapshotHealth = {
  snapshotted: modelArchiveEntries.filter((entry) => entry?.snapshotStatus === "snapshotted").length,
  partial: modelArchiveEntries.filter((entry) => entry?.snapshotStatus === "partial_snapshot").length,
  attention: modelArchiveEntries.filter((entry) => entry?.snapshotStatus === "snapshot_attention").length
};
const pendingSnapshotCount = modelCases.length - snapshotHealth.snapshotted - snapshotHealth.partial - snapshotHealth.attention;
const snapshotCoverage = modelCases.length ? Math.round((snapshotHealth.snapshotted / modelCases.length) * 100) : 0;
const modelCasesSorted = [...modelCases].sort((a, b) => String(b.collectedAt ?? "").localeCompare(String(a.collectedAt ?? "")));
const selectedCases = modelCases.filter((item) => item.selectedForModelCard);
const representativePool = selectedCases.length ? selectedCases : modelCases;
const archiveScore = (status: unknown) => {
  if (status === "snapshotted") return 45;
  if (status === "partial_snapshot") return 18;
  if (status === "snapshot_attention") return -35;
  return 0;
};
const isCodingSignal = (item: Record<string, unknown>) => /coding|code|software|agent|github|repo|pull request|pr|automation|tooling/.test([
  item.taskCategory,
  item.taskDescription,
  item.sourcePlatform,
  item.sourceType,
  item.artifactUrl
].join(" ").toLowerCase());
const representativeScore = (item: Record<string, any>) => {
  const trust = buildEvidenceTrust(item);
  const archiveEntry = evidenceArchiveMap.get(item.id);
  return (
    (item.selectedForModelCard ? 600 : 0) +
    trust.score +
    archiveScore(archiveEntry?.snapshotStatus) +
    (isCodingSignal(item) ? 20 : 0)
  );
};
const showcaseCases = [...representativePool].sort((a, b) => (
  representativeScore(b) - representativeScore(a) ||
  String(b.collectedAt ?? "").localeCompare(String(a.collectedAt ?? "")) ||
  String(a.id).localeCompare(String(b.id))
));
const topRepresentativeCase = showcaseCases[0];
const topRepresentativeTrust = topRepresentativeCase ? buildEvidenceTrust(topRepresentativeCase) : undefined;
const topRepresentativeArchive = topRepresentativeCase ? evidenceArchiveMap.get(topRepresentativeCase.id) : undefined;
const sameVendorModels = models
  .filter((item) => item.vendorId === model.vendorId && item.slug !== model.slug)
  .sort((a, b) => String(b.releaseDate ?? "").localeCompare(String(a.releaseDate ?? "")))
  .slice(0, 5);
const publishabilityLabel = publicStatusLabel(model.publishability);
const timeline = [
  { date: model.releaseDate, title: `${model.name} 资料状态`, summary: publicizeText(model.sourceStatus) },
  { date: "公开档案", title: "模型状态", summary: `${model.name} 当前标记为${publishabilityLabel}。` },
  { date: "案例库", title: "公开案例复核", summary: publicizeText(model.caseStatus) }
];
const hasACases = modelCases.length > 0;
const missingOfficial = !model.officialLink || String(model.officialLink).includes("artificialanalysis.ai");
const missingCase = model.aCaseCount === 0;
const hasOfficialSource = (model.sources ?? []).some((source) => !String(source).includes("artificialanalysis.ai"));
const hasFreshCaseReview = modelCasesSorted.some((item) => String(item.collectedAt ?? "").startsWith("2026-"));
const evidenceChecklist = [
  { label: "模型卡", value: model.sourceFile || "Model Atlas", complete: true },
  { label: "官方/厂商来源", value: hasOfficialSource ? `${model.supplementalSourceCount ?? 1} 个入口` : "待补强", complete: hasOfficialSource },
  { label: "A 类案例", value: `${modelCases.length} 条`, complete: hasACases },
  { label: "公开产物", value: hasACases ? "已绑定" : "暂无", complete: hasACases },
  { label: "风险备注", value: (model.riskNotes ?? []).length ? "已标注" : "待补充", complete: (model.riskNotes ?? []).length > 0 }
];
const evidenceCompletion = evidenceChecklist.filter((item) => item.complete).length;
const evidencePercent = Math.round((evidenceCompletion / evidenceChecklist.length) * 100);
const capabilityLabels: Array<[keyof typeof model.capabilities, string]> = [
  ["codingAgent", "Coding Agent"],
  ["longContext", "长上下文"],
  ["research", "研究任务"],
  ["openEcosystem", "开放生态"],
  ["lifecycleRisk", "生命周期风险"]
];
const capabilitySignals = capabilityLabels.map(([key, label]) => ({
  label,
  value: model.capabilities?.[key] ?? "暂无数据"
}));
const decisionSnapshot = [
  ["公开状态", publishabilityLabel, model.publishability === "Publishable" ? "可进入对比" : "仅作资料入口"],
  ["案例覆盖", `${modelCases.length} 条 A 类`, hasACases ? "有真实任务证据" : "暂不做能力推荐"],
  ["主要适用", publicizeText(model.fit?.[0] ?? "作为模型资料入口"), "来自模型卡"],
  ["谨慎场景", publicizeText(model.avoid?.[0] ?? "缺字段时不做推断"), "边界优先"]
];
const caseTimeline = modelCasesSorted.slice(0, 5).map((item) => ({
  date: item.collectedAt,
  title: item.title,
  summary: `${item.userOrOrg} / ${item.taskCategory}`,
  href: `/cases?case=${item.id}`
}));
const verificationSteps = [
  missingCase ? "优先寻找具体人/团队/组织发布的原始使用证据，且必须有公开产物链接。" : "继续保留 A 类案例的原始证据、产物页和版本快照。",
  missingOfficial ? "补官方发布/API/System Card 来源；若官方未披露，继续标注“官方未披露”。" : "复核官方来源与模型 ID、发布时间、平台可用性是否仍一致。",
  "把 benchmark、教程、发布文保留为背景资料，不提升为真实案例。"
];
const modelDate = Number.isFinite(Date.parse(String(model.releaseDate ?? ""))) ? model.releaseDate : undefined;
const modelJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: model.name,
  alternateName: model.modelId,
  applicationCategory: "AI Model",
  operatingSystem: "API / Web / Developer Tools",
  url: absoluteUrl(`/models/${model.slug}`),
  description: publicizeText(model.summary),
  datePublished: modelDate,
  inLanguage: "zh-CN",
  provider: {
    "@type": "Organization",
    name: model.vendor,
    url: absoluteUrl(`/vendors/${model.vendorId}`)
  },
  sameAs: httpLinks(model.sources ?? []),
  keywords: cleanList([
    model.vendor,
    model.modality,
    model.reasoning,
    model.capabilities?.codingAgent,
    model.capabilities?.longContext,
    "AI 模型",
    "模型档案",
    "A 类案例"
  ]),
  additionalProperty: [
    { "@type": "PropertyValue", name: "公开状态", value: publishabilityLabel },
    { "@type": "PropertyValue", name: "A 类案例", value: modelCases.length },
    { "@type": "PropertyValue", name: "证据完整度", value: `${evidencePercent}%` },
    { "@type": "PropertyValue", name: "证据快照覆盖率", value: `${snapshotCoverage}%` },
    { "@type": "PropertyValue", name: "上下文", value: model.context },
    { "@type": "PropertyValue", name: "价格", value: model.price },
    { "@type": "PropertyValue", name: "AA 评分", value: typeof model.score === "number" ? model.score : "暂无数据" }
  ]
};
---

<BaseLayout title={`${model.name} · Model Atlas 模型图谱`} description={`${model.name} 模型档案：公开资料、真实案例、证据等级和适用场景。`} jsonLd={modelJsonLd}>
  <section class="glass rounded-lg p-5">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="mono text-xs uppercase tracking-[0.16em] text-cyan-200">模型档案</p>
        <h1 class="mt-2 text-4xl font-semibold text-slate-50">{model.name}</h1>
        <p class="mt-3 max-w-3xl text-lg text-slate-300">{hasACases ? `${model.name} 已有可核验 A 类案例，可优先进入选型对比。` : `${model.name} 还没有找到符合 A 类标准的公开案例；本页保留资料、来源和缺口说明，不把缺口包装成推荐。`}</p>
        <div class="mt-5 flex flex-wrap gap-2 text-xs">
          <a class="border border-[#ff3b4e]/50 px-3 py-2 text-[#f4f1ea] hover:bg-[#ff3b4e]/10" href={`/cases?model=${model.id}`}>查看该模型案例</a>
          <a class="border border-[#f4f1ea]/20 px-3 py-2 text-[#f4f1ea] hover:border-[#ff3b4e]/60" href="/compare">加入对比视图</a>
          <a class="border border-[#f4f1ea]/20 px-3 py-2 text-[#f4f1ea] hover:border-[#ff3b4e]/60" href={`/vendors/${model.vendorId}`}>查看厂商路线</a>
          <button class="atlas-copy-button" type="button" data-copy-current-url data-copy-original="复制模型档案" data-copy-success="模型档案链接已复制">复制模型档案</button>
        </div>
      </div>
      <PublishabilityBadge status={model.publishability} />
    </div>
  </section>

  {model.publishability !== "Publishable" && (
    <div class="mt-5">
      <RiskNotice title={`${publishabilityLabel}提示`} tone={model.publishability === "Hold" || model.publishability === "Archive" ? "hold" : "limited"} notes={[model.caseStatus, "尚未找到符合 A 类标准的公开使用案例。", "此页面适合作为资料入口，不应被当作独立推荐结论。"]} />
    </div>
  )}

  <div class="content-grid mt-5">
    <section class="page-grid">
      <section class="panel p-4">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="mono text-xs uppercase tracking-[0.14em] text-slate-300">档案摘要 / Decision snapshot</p>
            <h2 class="mt-2 text-2xl font-semibold text-slate-50">先判断能不能用于选型。</h2>
          </div>
          <div class="mono border border-[#ff3b4e]/50 px-3 py-2 text-xs text-[#f4f1ea]">
            证据完整度 {evidencePercent}%
          </div>
        </div>
        <div class="mt-4 grid gap-px bg-[#f4f1ea]/15 md:grid-cols-2 xl:grid-cols-4">
          {decisionSnapshot.map(([title, value, note]) => (
            <article class="bg-[#050505] p-4">
              <span class="mono text-[11px] uppercase tracking-[0.12em] text-[#a8a29a]">{title}</span>
              <strong class="mt-3 block text-xl leading-tight text-[#f4f1ea]">{value}</strong>
              <p class="mt-2 text-sm leading-relaxed text-[#a8a29a]">{note}</p>
            </article>
          ))}
        </div>
      </section>

      <div class="panel p-5">
        <p class="mono text-xs uppercase tracking-[0.16em] text-[#ff3b4e]">30 秒结论</p>
        <h2 class="mt-3 max-w-3xl text-3xl font-semibold leading-tight text-[#f4f1ea] md:text-4xl">
          {hasACases ? "可进入选型对比，但仍以案例证据为准。" : "先作为资料入口，不包装成推荐结论。"}
        </h2>
        <p class="mt-4 max-w-4xl text-base leading-relaxed text-[#a8a29a] md:text-lg">{publicizeText(model.summary)}</p>
        <p class="mt-3 text-sm leading-relaxed text-[#a8a29a]">
          {hasACases ? "这页有来源、有风险说明、有公开可核验 A 类案例。" : "暂无 A 类案例不是能力否定，只说明当前公开证据还没有达到 Atlas 的精选标准。"}
        </p>
      </div>

      <EvidencePanel model={model} modelCases={modelCases} />

      <EvidenceDistribution modelName={model.name} modelId={model.id} cases={modelCases} />

      <section class="model-snapshot-health panel p-4" data-model-snapshot-health>
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="mono text-xs uppercase tracking-[0.14em] text-[#ff3b4e]">Evidence Snapshot</p>
            <h2 class="mt-2 text-2xl font-semibold text-[#f4f1ea]">证据快照覆盖</h2>
            <p class="mt-2 max-w-3xl text-sm leading-relaxed text-[#a8a29a]">
              {hasACases
                ? `${model.name} 的 ${modelCases.length} 条 A 类案例中，已有 ${snapshotHealth.snapshotted} 条完成本地证据快照；${pendingSnapshotCount} 条仍在快照队列。`
                : "暂无 A 类案例，因此还没有可执行的证据快照目标。"}
            </p>
          </div>
          <div class="mono border border-[#ff3b4e]/50 px-3 py-2 text-xs text-[#f4f1ea]">
            SNAPSHOT {snapshotCoverage}%
          </div>
        </div>
        <div class="mt-4 grid gap-px bg-[#f4f1ea]/15 sm:grid-cols-2 lg:grid-cols-4">
          {[
            ["已快照", snapshotHealth.snapshotted, "可用 manifest 复核"],
            ["待快照", pendingSnapshotCount, "等待落盘"],
            ["部分快照", snapshotHealth.partial, "需补抓"],
            ["需关注", snapshotHealth.attention, "需人工复核"]
          ].map(([label, value, note]) => (
            <article class="bg-[#050505] p-4">
              <span class="mono text-[11px] uppercase tracking-[0.12em] text-[#a8a29a]">{label}</span>
              <strong class="mt-3 block text-3xl leading-none text-[#f4f1ea]">{value}</strong>
              <p class="mt-2 text-sm leading-relaxed text-[#a8a29a]">{note}</p>
            </article>
          ))}
        </div>
        <div class="mt-4 flex flex-wrap gap-2 text-sm">
          <a class="border border-[#f4f1ea]/20 px-3 py-2 text-[#f4f1ea] hover:border-[#ff3b4e]/60" href={`/cases?model=${model.id}&snapshot=snapshotted`}>查看已快照案例</a>
          <a class="border border-[#ff3b4e]/50 px-3 py-2 text-[#f4f1ea] hover:bg-[#ff3b4e]/10" href={`/cases?model=${model.id}&snapshot=pending_snapshot`}>查看待快照案例</a>
        </div>
      </section>

      <section class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_300px]">
        <div class="panel p-4">
          <div class="flex items-center justify-between gap-3">
            <p class="mono text-xs uppercase tracking-[0.14em] text-slate-300">证据完整度</p>
            <p class="mono text-xs text-[#ff3b4e]">{evidenceCompletion} / {evidenceChecklist.length}</p>
          </div>
          <div class="mt-3 h-2 border border-[#f4f1ea]/20 bg-[#050505]">
            <div class="h-full bg-[#ff3b4e]" style={`width: ${evidencePercent}%`}></div>
          </div>
          <div class="mt-4 grid gap-2 sm:grid-cols-2">
            {evidenceChecklist.map((item) => (
              <div class="border border-[#f4f1ea]/15 bg-[#050505] p-3">
                <div class="flex items-center justify-between gap-3">
                  <span class="text-sm font-semibold text-[#f4f1ea]">{item.label}</span>
                  <span class={item.complete ? "mono text-xs text-[#ff3b4e]" : "mono text-xs text-[#a8a29a]"}>{item.complete ? "OK" : "GAP"}</span>
                </div>
                <p class="mt-1 text-sm text-[#a8a29a]">{item.value}</p>
              </div>
            ))}
          </div>
        </div>
        <aside class="panel p-4">
          <p class="mono text-xs uppercase tracking-[0.14em] text-slate-300">最近复核</p>
          <p class="mt-3 text-3xl font-semibold text-[#f4f1ea]">{hasFreshCaseReview ? modelCasesSorted[0]?.collectedAt : "待补"}</p>
          <p class="mt-3 text-sm leading-relaxed text-[#a8a29a]">
            {hasFreshCaseReview ? "该模型已有 2026 年采集的公开案例证据，可继续进入案例级复核。" : "尚未看到近期案例复核日期，适合作为下一轮补证目标。"}
          </p>
        </aside>
      </section>

      <section class="panel p-4">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="mono text-xs uppercase tracking-[0.14em] text-slate-300">能力边界</p>
            <h2 class="mt-2 text-2xl font-semibold text-slate-50">用标签表达信号，不用标签替代证据。</h2>
          </div>
          <a class="link-accent text-sm" href="/methodology">查看证据方法</a>
        </div>
        <div class="mt-4 grid gap-px bg-[#f4f1ea]/15 md:grid-cols-5">
          {capabilitySignals.map((item) => (
            <div class="bg-[#050505] p-4">
              <span class="mono text-[11px] uppercase tracking-[0.12em] text-[#a8a29a]">{item.label}</span>
              <p class="mt-3 text-sm font-semibold leading-relaxed text-[#f4f1ea]">{item.value}</p>
            </div>
          ))}
        </div>
      </section>

      <div class="panel">
        <table class="data-table key-value-table">
          <tbody>
            <tr><th>厂商</th><td>{model.vendor}</td></tr>
            <tr><th>厂商页</th><td><a class="link-accent" href={`/vendors/${model.vendorId}`}>{model.vendor}</a></td></tr>
            <tr><th>发布时间</th><td>{model.releaseDate}</td></tr>
            <tr><th>模型 ID</th><td>{model.modelId}</td></tr>
            <tr><th>上下文</th><td>{model.context}</td></tr>
            <tr><th>输出</th><td>{model.output}</td></tr>
            <tr><th>模态</th><td>{model.modality}</td></tr>
            <tr><th>推理</th><td>{model.reasoning}</td></tr>
            <tr><th>价格</th><td>{model.price}</td></tr>
            <tr><th>可用平台</th><td>{model.platforms.join(", ")}</td></tr>
            <tr><th>AA 评分</th><td>{typeof model.score === "number" ? model.score : "暂无数据"}</td></tr>
            <tr><th>基础模型发布时间</th><td>{model.baseModelReleaseDate}</td></tr>
            <tr><th>资料来源</th><td>公开资料、厂商信息和案例库</td></tr>
            <tr><th>A 类案例</th><td>{model.aCaseCount}</td></tr>
          </tbody>
        </table>
      </div>

      <div>
        <SectionHeader eyebrow="谱系位置" title="它在厂商路线中的位置" description={`此页将 ${model.name} 放入 ${model.vendor} 的当前 Atlas 路线中。若同厂前后代资料不足，先保留为路线追踪入口，不脑补谱系关系。`} />
        <ModelTimeline items={timeline} />
      </div>

      {caseTimeline.length > 0 && (
        <div>
          <SectionHeader eyebrow="案例时间线" title="最近进入档案的 A 类案例" description="用采集时间呈现证据进入 Atlas 的顺序，方便复核来源新鲜度。" />
          <ModelTimeline items={caseTimeline} />
        </div>
      )}

      <div class="grid gap-4 md:grid-cols-2">
        <div class="panel p-4">
          <p class="font-semibold">适合场景</p>
          <ul class="mt-3 space-y-2 text-sm text-slate-300">
            {model.fit.map((item) => <li>- {publicizeText(item)}</li>)}
          </ul>
        </div>
        <div class="panel p-4">
          <p class="font-semibold">不适合</p>
          <ul class="mt-3 space-y-2 text-sm text-slate-300">
            {model.avoid.map((item) => <li>- {publicizeText(item)}</li>)}
          </ul>
        </div>
      </div>

      <div>
        <SectionHeader eyebrow="真实案例" title={modelCases.length ? "可核验 A 类案例精选" : "未找到可核验公开 A 类案例"} description={modelCases.length ? `当前展示 ${showcaseCases.length} 条代表案例；排序优先看模型卡精选、证据可信度、快照状态和公开仓库/技术任务信号。案例总数仍为 ${model.aCaseCount}。` : "页面不会用 benchmark、教程、发布说明或集合页替代真实案例。"} />
        {modelCases.length > 0 && topRepresentativeCase && (
          <section class="mb-3 min-w-0 border border-[#f4f1ea]/20 bg-[#050505] p-4" data-representative-cases>
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div class="min-w-0">
                <p class="mono text-xs uppercase tracking-[0.14em] text-[#ff3b4e]">Representative Evidence</p>
                <h3 class="mt-2 text-xl font-semibold text-[#f4f1ea]">代表案例排序</h3>
                <p class="mt-2 max-w-3xl break-words text-sm leading-relaxed text-[#a8a29a]">
                  当前第一代表案例是“{topRepresentativeCase.title}”。它会优先出现在本页，是因为该案例同时进入模型卡精选、具备 {topRepresentativeTrust?.score ?? 0}/100 的证据可信度，并带有 {topRepresentativeArchive?.snapshotStatus === "snapshotted" ? "已快照证据" : "待快照证据队列"}。
                </p>
              </div>
              <a class="border border-[#ff3b4e]/50 px-3 py-2 text-sm text-[#f4f1ea] hover:bg-[#ff3b4e]/10" href={`/cases?case=${topRepresentativeCase.id}`}>打开第一代表案例</a>
            </div>
            <div class="mt-4 grid gap-px bg-[#f4f1ea]/15 text-sm sm:grid-cols-2 lg:grid-cols-4">
              {[
                ["排序池", `${representativePool.length} 条`, selectedCases.length ? "模型卡精选优先" : "全部 A 类案例"],
                ["证据可信度", `${topRepresentativeTrust?.score ?? 0}/100`, topRepresentativeTrust?.tier ?? "待复核"],
                ["快照状态", topRepresentativeArchive?.snapshotStatus === "snapshotted" ? "已快照" : "待快照", topRepresentativeArchive?.localSnapshotManifest ?? "等待归档"],
                ["技术信号", isCodingSignal(topRepresentativeCase) ? "命中" : "未命中", "Coding / repo / agent"]
              ].map(([label, value, note]) => (
                <article class="min-w-0 bg-[#070707] p-3">
                  <span class="mono text-[11px] uppercase tracking-[0.12em] text-[#a8a29a]">{label}</span>
                  <strong class="mt-2 block min-w-0 break-words text-lg leading-tight text-[#f4f1ea]">{value}</strong>
                  <p class="mt-1 min-w-0 overflow-hidden break-all text-xs text-[#a8a29a]">{note}</p>
                </article>
              ))}
            </div>
          </section>
        )}
        {modelCases.length ? <div class="grid gap-3 md:grid-cols-2">{showcaseCases.map((item) => <CaseCard item={item} />)}</div> : (
          <div class="panel p-4 text-sm leading-relaxed text-slate-300">
            <p class="font-semibold text-slate-100">暂无可核验 A 类案例</p>
            <p class="mt-2">尚未找到符合 A 类标准的公开使用案例。Atlas 不会把 C 类文档、benchmark、教程、集合页或发布说明当作真实案例。</p>
            <p class="mt-2">这不是对模型能力的否定，只是说明当前公开证据还不足以进入案例精选。</p>
            <p class="mt-2 text-slate-400">当前状态：{publishabilityLabel}。</p>
          </div>
        )}
      </div>

      <div class="grid gap-4 lg:grid-cols-2">
        <DataGapPanel model={model} />
        <div class="panel p-4">
          <p class="mono text-xs uppercase tracking-[0.14em] text-slate-300">下一步验证建议</p>
          <ul class="mt-3 space-y-2 text-sm text-slate-300">
            {verificationSteps.map((item) => <li>- {item}</li>)}
          </ul>
        </div>
      </div>

      {!hasACases && (
        <div class="panel p-4">
          <p class="font-semibold text-slate-100">继续判断入口</p>
          <div class="mt-3 flex flex-wrap gap-2 text-sm">
            <a class="rounded-md border border-cyan-300/30 px-3 py-2 text-cyan-100" href="/models">返回模型索引</a>
            <a class="rounded-md border border-cyan-300/30 px-3 py-2 text-cyan-100" href="/compare">进入对比页</a>
            {sameVendorModels.map((item) => <a class="rounded-md border border-slate-700/70 px-3 py-2 text-slate-200" href={`/models/${item.slug}`}>{item.name}</a>)}
          </div>
        </div>
      )}
    </section>

    <aside class="page-grid">
      <RiskNotice title="风险和限制" tone={model.publishability === "Hold" || model.publishability === "Archive" ? "hold" : model.publishability === "Limited" ? "limited" : "neutral"} notes={model.riskNotes} />
      <SourceLinkBlock sources={model.sources} />
      <div class="panel p-4">
        <p class="mono text-xs uppercase tracking-[0.14em] text-slate-300">一句话使用建议</p>
        <p class="mt-2 text-sm leading-relaxed text-slate-300">{publicizeText(model.fit[0])} · 状态：{publishabilityLabel}</p>
      </div>
      <div class="panel p-4">
        <p class="mono text-xs uppercase tracking-[0.14em] text-slate-300">同厂相邻模型</p>
        <div class="mt-3 grid gap-2">
          {sameVendorModels.map((item) => (
            <a class="border border-[#f4f1ea]/15 bg-[#050505] p-3 text-sm hover:border-[#ff3b4e]/60" href={`/models/${item.slug}`}>
              <span class="block font-semibold text-[#f4f1ea]">{item.name}</span>
              <span class="mt-1 block text-xs text-[#a8a29a]">{item.releaseDate} · {item.aCaseCount ?? 0} 条 A 类案例</span>
            </a>
          ))}
        </div>
      </div>
    </aside>
  </div>
</BaseLayout>
