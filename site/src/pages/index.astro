---
import BaseLayout from "../components/layout/BaseLayout.astro";
import models from "../data/models.json";
import cases from "../data/cases.json";
import vendors from "../data/vendors.json";
import metrics from "../data/metrics.json";
import { buildCaseNarrative } from "../lib/caseNarrative";
import { absoluteUrl } from "../lib/seo";

const activeModels = models.filter((model) => !["Archive", "Hold"].includes(model.publishability));
const verifiedCases = cases.filter((item) => item.evidenceGrade === "A" && item.showcaseEligible);
const featuredModels = [...activeModels]
  .sort((a, b) => (b.aCaseCount ?? 0) - (a.aCaseCount ?? 0) || (b.score ?? 0) - (a.score ?? 0))
  .slice(0, 6);
const featuredCases = verifiedCases.slice(0, 6);
const codingCandidateCount = models.filter((model) => {
  const signal = String(model.capabilities?.codingAgent ?? "").toLowerCase();
  return signal.includes("agent") || String(model.reasoning ?? "").includes("是");
}).length;
const latestCases = [...verifiedCases]
  .sort((a, b) => String(b.collectedAt ?? "").localeCompare(String(a.collectedAt ?? "")))
  .slice(0, 4);
const latestModels = [...models]
  .filter((model) => model.releaseDate && model.releaseDate !== "暂无数据")
  .sort((a, b) => String(b.releaseDate ?? "").localeCompare(String(a.releaseDate ?? "")))
  .slice(0, 4);
const formatDate = (value: string | null | undefined) => String(value ?? metrics.datasetCut).slice(0, 10);
const latestCaseDate = formatDate(latestCases[0]?.collectedAt);
const latestModelDate = formatDate(latestModels[0]?.releaseDate);
const pulseCards = [
  ["数据截面", metrics.datasetCut, "当前页面由本地 JSON 生成，缺失字段保持显式空值。"],
  ["最近案例复核", latestCaseDate, `${latestCases[0]?.modelName ?? "模型"} / ${latestCases[0]?.sourcePlatform ?? "公开来源"}`],
  ["最近模型发布", latestModelDate, latestModels[0]?.name ?? "持续补齐模型卡"],
  ["自动化链路", "Hermes → 主表 → Astro", "进入结构化主表后才会发布到静态站点。"]
];

const statCards = [
  ["活跃模型", metrics.activeModels ?? activeModels.length, "个", "当前纳入全量补齐目标的模型。"],
  ["A 类精选案例", metrics.verifiedACases ?? verifiedCases.length, "条", "公开可核验、可进入对外展示的真实使用案例。"],
  ["覆盖达标模型", metrics.activeModelsMeetingTargetCaseCoverage ?? 0, "个", "达到 5 条 A 类精选案例的活跃模型。"],
  ["剩余目标缺口", metrics.activeCaseDeficitToTarget ?? 0, "", "活跃模型全量补齐目标当前无剩余缺口。"]
];

const modelIndexCards = [
  ["厂商索引", `${vendors.length} 个厂商`, "从 OpenAI、Anthropic、Google、Qwen、DeepSeek 等厂商进入模型路线。", "/vendors"],
  ["能力索引", `${codingCandidateCount} 个 Coding Agent 候选`, "按编码代理、长上下文、多模态、研究和开放生态信号切片。", "/models?quick=coding"],
  ["A 类覆盖", `${metrics.modelsWithCases} 个模型`, "只看已有公开可核验案例支撑的模型。", "/models?quick=with-cases"],
  ["活跃模型", `${metrics.activeModels ?? activeModels.length} 个活跃模型`, "优先浏览仍计入补齐目标的模型。", "/models?status=Publishable"],
  ["归档模型", `${metrics.archiveModels ?? 0} 个归档`, "把历史模型从主动选型里区分出来。", "/models?status=Archive"]
];

const graphNodes = [
  ...featuredModels.map((model) => ({
    label: model.name,
    href: `/models/${model.slug}`,
    type: "MODEL",
    hot: Number(model.aCaseCount ?? 0) >= 5
  })),
  ...featuredCases.slice(0, 24).map((item) => ({
    label: buildCaseNarrative(item).displayTitle,
    href: `/cases?case=${item.id}`,
    type: "CASE",
    hot: item.evidenceGrade === "A"
  }))
];

const compareCards = [
  ["Coding Agent 对比", "工具调用、repo 修改、PR 工作流和真实 GitHub 证据。", "/topics/coding-agent"],
  ["模型横向对比", "按价格、上下文、证据覆盖、风险和真实案例筛选。", "/compare"],
  ["厂商路线对比", "从厂商、模型家族和发布节奏理解能力边界。", "/vendors"]
];

const automationSteps = [
  ["Hermes", "自动抓取模型资料和真实使用案例候选；云文档用于沉淀模型卡草稿。"],
  ["飞书结构化主表", "结构化维护模型卡、案例等级、证据 URL、产物 URL 和审核状态；只有主表记录会进入发布链路。"],
  ["Astro 静态网站", "从本地 JSON 生成首页、厂商页、模型库、案例库、对比页和专题页。"],
  ["Vercel 部署", "GitHub 推送后触发构建，把最新资料库发布到线上。"]
];

const evidenceGrades = [
  ["A", "公开可核验的真实使用案例，可进入精选展示。"],
  ["B", "有价值但模型绑定较弱或证据不足，保留为候选。"],
  ["C", "背景材料，用于理解模型、厂商或场景。"],
  ["D", "证据不足、不可采用，或不属于真实使用案例。"]
];
const homeJsonLd = {
  "@context": "https://schema.org",
  "@type": "Dataset",
  name: "Model Atlas 模型图谱",
  description: "自动维护的 AI 模型资料库和公开可核验真实使用案例库，覆盖模型档案、厂商路线、A 类案例证据和模型对比入口。",
  url: absoluteUrl("/"),
  inLanguage: "zh-CN",
  dateModified: metrics.datasetCut,
  keywords: ["AI 模型", "模型图谱", "模型资料库", "真实使用案例", "Coding Agent", "A 类证据"],
  creator: {
    "@type": "Organization",
    name: "Model Atlas"
  },
  variableMeasured: [
    { "@type": "PropertyValue", name: "活跃模型", value: metrics.activeModels },
    { "@type": "PropertyValue", name: "A 类精选案例", value: metrics.verifiedACases },
    { "@type": "PropertyValue", name: "覆盖达标模型", value: metrics.activeModelsMeetingTargetCaseCoverage },
    { "@type": "PropertyValue", name: "活跃模型剩余目标缺口", value: metrics.activeCaseDeficitToTarget }
  ],
  distribution: [
    {
      "@type": "DataDownload",
      encodingFormat: "application/json",
      contentUrl: absoluteUrl("/command-index.json")
    },
    {
      "@type": "DataDownload",
      encodingFormat: "application/json",
      contentUrl: absoluteUrl("/atlas.json")
    },
    {
      "@type": "DataDownload",
      encodingFormat: "text/plain",
      contentUrl: absoluteUrl("/llms.txt")
    }
  ]
};

const parseDateMs = (value: unknown) => {
  const time = Date.parse(String(value ?? ""));
  return Number.isFinite(time) ? time : 0;
};
const datasetCutMs = parseDateMs(metrics.datasetCut);
const latestCaseMs = Math.max(...cases.map((item) => parseDateMs(item.collectedAt)));
const daysSinceLatestCase = Math.max(0, Math.floor((datasetCutMs - latestCaseMs) / 86400000));
const approvedCases = cases.filter((item) => String(item.reviewStatus ?? "").includes("approved")).length;
const activeCoverageRate = Math.round(((metrics.activeModelsMeetingTargetCaseCoverage ?? 0) / Math.max(1, metrics.activeModels ?? activeModels.length)) * 100);
const aCaseShare = ((metrics.verifiedACases ?? verifiedCases.length) / Math.max(1, cases.length)) * 100;
const platformLabels: Record<string, string> = {
  github: "GitHub",
  official_web: "official_web",
  huggingface: "huggingface",
  "hugging face spaces": "Hugging Face Spaces"
};
const platformCounts = cases.reduce<Record<string, { label: string; count: number; query: string }>>((acc, item) => {
  const rawPlatform = String(item.sourcePlatform ?? "未知来源");
  const key = rawPlatform.trim().toLowerCase();
  const label = platformLabels[key] ?? rawPlatform;
  acc[key] = {
    label,
    query: rawPlatform,
    count: (acc[key]?.count ?? 0) + 1
  };
  return acc;
}, {});
const topPlatforms = Object.values(platformCounts)
  .sort((a, b) => b.count - a.count)
  .slice(0, 5);
const healthCards = [
  ["最近证据入库", `${daysSinceLatestCase} 天内`, `${formatDate(latestCases[0]?.collectedAt)} / ${latestCases[0]?.sourcePlatform ?? "公开来源"}`],
  ["A 类证据占比", `${aCaseShare.toFixed(1)}%`, `${metrics.verifiedACases ?? verifiedCases.length} / ${cases.length} 条案例进入精选口径`],
  ["活跃模型覆盖", `${activeCoverageRate}%`, `${metrics.activeModelsMeetingTargetCaseCoverage ?? 0} / ${metrics.activeModels ?? activeModels.length} 个活跃模型达到 5 条目标`],
  ["自动 Gate 通过", `${approvedCases}`, "reviewStatus 已标记 approved 的公开案例档案"]
];
---

<BaseLayout title="Model Atlas 模型图谱 · AI 模型资料库与真实案例库" description="Model Atlas 模型图谱是自动维护的 AI 模型资料库和公开可核验真实使用案例库。" jsonLd={homeJsonLd}>
  <div class="ma-page">
    <section class="ma-hero">
      <div class="ma-hero-copy">
        <p class="ma-kicker">自动维护的 AI 模型资料库 / 真实使用案例库</p>
        <h1>
          <span>Model Atlas</span>
          <span>模型图谱</span>
          <span>持续更新。</span>
        </h1>
        <p class="ma-lede">
          从飞书结构化主表同步模型卡，用 Hermes 补充公开可核验案例，再生成可发布的 Astro 静态网站。
        </p>
        <div class="ma-actions">
          <a class="ma-button primary" href="/models?quick=with-cases">浏览模型库 <span>→</span></a>
          <a class="ma-button" href="/cases">查看案例库 <span>→</span></a>
          <a class="ma-button" href="/compare">对比模型 <span>→</span></a>
        </div>
      </div>

      <div class="ma-stage" aria-label="模型、案例和证据组成的粒子知识图谱">
        <canvas id="model-atlas-graph"></canvas>
        <div id="model-atlas-graph-tip" class="ma-stage-tip" hidden></div>
        <div class="ma-stage-label">
          <strong>模型知识图谱</strong>
          <span>MODEL / CASE / EVIDENCE</span>
        </div>
        <div class="ma-stage-badge"><i></i>A 类证据节点</div>
        <div class="ma-stage-foot">
          <span>模型 {metrics.activeModels ?? activeModels.length}</span>
          <span>案例 {metrics.verifiedACases ?? verifiedCases.length}</span>
          <span>缺口 {metrics.activeCaseDeficitToTarget ?? 0}</span>
        </div>
      </div>
    </section>

    <section class="ma-proof" aria-label="指标概览">
      {statCards.map(([title, value, suffix, detail]) => (
        <a href={title === "A 类精选案例" ? "/cases" : "/models"} class="ma-proof-card">
          <span>{title}</span>
          <strong>{value}<em>{suffix}</em></strong>
          <p>{detail}</p>
        </a>
      ))}
    </section>

    <section class="ma-section ma-pulse" aria-label="数据脉冲">
      <div class="ma-section-head split">
        <div>
          <p class="ma-kicker">数据脉冲</p>
          <h2>这不是静态宣传页，是持续更新的模型档案。</h2>
          <p>用最新案例复核、模型发布时间和自动化链路，把“资料库还活着”直接暴露出来。</p>
        </div>
        <a class="ma-button" href="/updates">查看更新日志 <span>→</span></a>
      </div>
      <div class="ma-pulse-grid">
        {pulseCards.map(([title, value, copy]) => (
          <article>
            <span>{title}</span>
            <strong>{value}</strong>
            <p>{copy}</p>
          </article>
        ))}
      </div>
      <div class="ma-pulse-stream">
        <div>
          <span>最近案例</span>
          {latestCases.map((item) => (
            <a href={`/cases?case=${item.id}`}>
              <strong>{buildCaseNarrative(item).displayTitle}</strong>
              <em>{formatDate(item.collectedAt)} / {buildCaseNarrative(item).useCaseLabel} / 证据档案</em>
            </a>
          ))}
        </div>
        <div>
          <span>最近模型</span>
          {latestModels.map((model) => (
            <a href={`/models/${model.slug}`}>
              <strong>{model.name}</strong>
              <em>{model.releaseDate} / {model.vendor}</em>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="ma-section ma-health" aria-label="数据健康与证据新鲜度">
      <div class="ma-section-head split">
        <div>
          <p class="ma-kicker">数据健康</p>
          <h2>每一次浏览，都带着证据状态。</h2>
          <p>Model Atlas 把资料库的覆盖率、复核时间、证据等级和来源结构放在前台，让用户判断这套索引是否值得依赖。</p>
        </div>
        <a class="ma-button" href="/methodology">查看证据规则 <span>→</span></a>
      </div>
      <div class="ma-health-grid">
        <div class="ma-health-score">
          <span class="ma-kicker">ACTIVE COVERAGE</span>
          <strong>{activeCoverageRate}%</strong>
          <p>活跃模型已达到 5 条 A 类精选案例的目标线。剩余目标缺口：{metrics.activeCaseDeficitToTarget ?? 0}。</p>
          <div>
            <i></i>
            <span>dataset cut / {metrics.datasetCut}</span>
          </div>
        </div>
        <div class="ma-health-cards">
          {healthCards.map(([title, value, copy]) => (
            <article>
              <span>{title}</span>
              <strong>{value}</strong>
              <p>{copy}</p>
            </article>
          ))}
        </div>
        <div class="ma-health-platforms">
          <span class="ma-kicker">SOURCE STRUCTURE</span>
          <div>
            {topPlatforms.map((platform) => (
              <a href={`/cases?q=${encodeURIComponent(platform.query)}`}>
                <strong>{platform.label}</strong>
                <em>{platform.count} 条</em>
                <i style={`--w:${Math.max(6, Math.round((platform.count / cases.length) * 100))}%`}></i>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="ma-section ma-index" id="models">
      <div class="ma-section-head">
        <p class="ma-kicker">模型索引</p>
        <h2>按厂商、能力与状态浏览。</h2>
        <p>Model Atlas 不把模型当作一串名字，而是维护模型卡、厂商关系、发布状态、能力标签和案例覆盖。</p>
      </div>
      <div class="ma-index-grid">
        {modelIndexCards.map(([title, stat, copy, href], index) => (
          <a class="ma-line-card" href={href}>
            <span>0{index + 1}</span>
            <strong>{title}</strong>
            <em>{stat}</em>
            <p>{copy}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="ma-section">
      <div class="ma-section-head split">
        <div>
          <p class="ma-kicker">活跃模型切片</p>
          <h2>先看有证据覆盖的模型。</h2>
        </div>
        <a class="ma-button" href="/models">进入完整模型库 <span>→</span></a>
      </div>
      <div class="ma-model-grid">
        {featuredModels.map((model) => (
          <a class="ma-model-card" href={`/models/${model.slug}`}>
            <span>{model.vendor}</span>
            <strong>{model.name}</strong>
            <p>{model.summary}</p>
            <div>
              <em>{model.aCaseCount ?? 0} 条 A 类案例</em>
              <em>AA {typeof model.score === "number" ? model.score : "暂无"}</em>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="ma-section" id="cases">
      <div class="ma-section-head split">
        <div>
          <p class="ma-kicker">真实案例库</p>
          <h2>A 类公开可核验案例。</h2>
          <p>首页只展示真实使用案例，不把 benchmark、教程、发布说明或模型列表包装成案例。</p>
        </div>
        <a class="ma-button" href="/cases">查看案例库 <span>→</span></a>
      </div>
      <div class="ma-case-grid">
        {featuredCases.map((item) => (
          <a class="ma-case-card" href={`/cases?case=${item.id}`}>
            <span>{buildCaseNarrative(item).platformLabel} / {item.modelName}</span>
            <strong>{buildCaseNarrative(item).displayTitle}</strong>
            <p>{buildCaseNarrative(item).summary}</p>
            <em>{item.userOrOrg} · A 类证据 · 打开证据档案</em>
          </a>
        ))}
      </div>
    </section>

    <section class="ma-section ma-compare" id="compare">
      <div>
        <p class="ma-kicker">模型对比</p>
        <h2>从真实任务进入 compare。</h2>
      </div>
      <div class="ma-compare-list">
        {compareCards.map(([title, copy, href], index) => (
          <a href={href}>
            <span>0{index + 1}</span>
            <strong>{title}</strong>
            <p>{copy}</p>
            <em>→</em>
          </a>
        ))}
      </div>
    </section>

    <section class="ma-section ma-topic" id="coding-agent">
      <div>
        <p class="ma-kicker">Coding Agent 专题</p>
        <h2>从真实 repo 看模型能力。</h2>
      </div>
      <div>
        <p>
          专题聚合与代码代理、自动修复、PR 工作流、工具调用相关的 A 类案例，让模型对比不只停留在 benchmark。
        </p>
        <div class="ma-tags">
          <span>GitHub 证据</span>
          <span>真实任务</span>
          <span>模型贡献</span>
        </div>
        <a class="ma-button primary" href="/topics/coding-agent">查看 Coding Agent 专题 <span>→</span></a>
      </div>
    </section>

    <section class="ma-section ma-flow">
      <div class="ma-section-head">
        <p class="ma-kicker">自动化流程</p>
        <h2>Hermes → 飞书结构化主表 → Astro 静态网站 → Vercel 部署</h2>
      </div>
      <div class="ma-flow-grid">
        {automationSteps.map(([title, copy], index) => (
          <article>
            <span>阶段 0{index + 1}</span>
            <strong>{title}</strong>
            <p>{copy}</p>
          </article>
        ))}
      </div>
      <p class="mt-4 max-w-3xl text-sm leading-relaxed text-slate-400">
        发布边界：飞书 Wiki/云文档是模型卡草稿和溯源档案；模型必须写入结构化主表，或被标记为官方来源补丁，才会进入本地 JSON、Astro 构建和 Vercel 发布。
      </p>
      <div class="mt-4">
        <a class="ma-button" href="/updates">查看最近入库与数据更新 <span>→</span></a>
      </div>
    </section>

    <section class="ma-section ma-evidence" id="evidence">
      <div>
        <p class="ma-kicker">证据分级</p>
        <h2>只让强证据进入精选展示。</h2>
      </div>
      <div class="ma-evidence-list">
        {evidenceGrades.map(([grade, copy]) => (
          <div>
            <strong>{grade}</strong>
            <p>{copy}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="ma-final">
      <p class="ma-kicker">Model Atlas 模型图谱</p>
      <h2>从模型资料走向真实证据。</h2>
      <div class="ma-actions">
        <a class="ma-button primary" href="/models?quick=with-cases">浏览模型库 <span>→</span></a>
        <a class="ma-button" href="/cases">查看案例库 <span>→</span></a>
        <a class="ma-button" href="/compare">对比模型 <span>→</span></a>
        <a class="ma-button" href="/updates">查看更新日志 <span>→</span></a>
        <a class="ma-button" href="/topics/coding-agent">查看 Coding Agent 专题 <span>→</span></a>
      </div>
    </section>
  </div>

  <script is:inline define:vars={{ graphNodes }}>
    const canvas = document.getElementById("model-atlas-graph");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (canvas instanceof HTMLCanvasElement) {
      const context = canvas.getContext("2d");
      let width = 0;
      let height = 0;
      let raf = 0;
      let nodes = [];
      let pointer = { x: 0.62, y: 0.42 };
      let activeNode = null;
      const red = "#ff3b4e";
      const labels = Array.isArray(graphNodes) ? graphNodes : [];

      const resize = () => {
        const rect = canvas.getBoundingClientRect();
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        width = rect.width;
        height = rect.height;
        canvas.width = Math.floor(width * dpr);
        canvas.height = Math.floor(height * dpr);
        context?.setTransform(dpr, 0, 0, dpr, 0, 0);
        const count = Math.max(88, Math.floor(width / 6));
        nodes = Array.from({ length: count }, (_, index) => {
          const cluster = index % 6;
          const baseX = [0.18, 0.36, 0.54, 0.72, 0.84, 0.48][cluster] * width;
          const baseY = [0.34, 0.58, 0.26, 0.62, 0.42, 0.48][cluster] * height;
          return {
            x: baseX + (Math.random() - 0.5) * width * 0.3,
            y: baseY + (Math.random() - 0.5) * height * 0.36,
            vx: (Math.random() - 0.5) * 0.16,
            vy: (Math.random() - 0.5) * 0.16,
            r: Math.random() > 0.82 ? 2.7 : 1.2,
            doc: Math.random() > 0.76,
            hot: labels[index % labels.length]?.hot ?? index % 31 === 0,
            label: labels[index % labels.length]?.label ?? "",
            href: labels[index % labels.length]?.href ?? "",
            type: labels[index % labels.length]?.type ?? "NODE"
          };
        });
      };

      const draw = () => {
        if (!context) return;
        context.clearRect(0, 0, width, height);
        context.fillStyle = "rgba(5,5,5,0.38)";
        context.fillRect(0, 0, width, height);

        context.strokeStyle = "rgba(244,241,234,0.08)";
        context.lineWidth = 1;
        for (let x = 24; x < width; x += 32) {
          context.beginPath();
          context.moveTo(x, 0);
          context.lineTo(x, height);
          context.stroke();
        }
        for (let y = 24; y < height; y += 32) {
          context.beginPath();
          context.moveTo(0, y);
          context.lineTo(width, y);
          context.stroke();
        }

        nodes.forEach((node, index) => {
          if (!reduceMotion) {
            const px = pointer.x * width;
            const py = pointer.y * height;
            const dx = px - node.x;
            const dy = py - node.y;
            const dist = Math.max(80, Math.hypot(dx, dy));
            node.x += node.vx + (dx / dist) * 0.014;
            node.y += node.vy + (dy / dist) * 0.014;
            if (node.x < 8 || node.x > width - 8) node.vx *= -1;
            if (node.y < 8 || node.y > height - 8) node.vy *= -1;
          }
          for (let j = index + 1; j < nodes.length; j += 1) {
            const other = nodes[j];
            const dist = Math.hypot(node.x - other.x, node.y - other.y);
            if (dist < 100) {
              context.strokeStyle = `rgba(244,241,234,${0.15 - dist / 780})`;
              context.beginPath();
              context.moveTo(node.x, node.y);
              context.lineTo(other.x, other.y);
              context.stroke();
            }
          }
        });

        nodes.forEach((node) => {
          const isActive = activeNode === node;
          if (node.doc) {
            context.strokeStyle = isActive || node.hot ? red : "rgba(244,241,234,0.5)";
            context.lineWidth = isActive ? 2 : 1;
            context.strokeRect(node.x - 5, node.y - 6, 10, 13);
            context.beginPath();
            context.moveTo(node.x - 2, node.y - 1);
            context.lineTo(node.x + 3, node.y - 1);
            context.moveTo(node.x - 2, node.y + 3);
            context.lineTo(node.x + 2, node.y + 3);
            context.stroke();
          } else {
            context.beginPath();
            context.arc(node.x, node.y, isActive ? node.r + 2.5 : node.r, 0, Math.PI * 2);
            context.fillStyle = isActive || node.hot ? red : "rgba(244,241,234,0.8)";
            context.fill();
          }
        });

        nodes.forEach((node, index) => {
          if (node.label && index % 19 === 0) {
            context.font = "10px ui-monospace, SFMono-Regular, monospace";
            context.fillStyle = node.hot ? "rgba(255,59,78,0.78)" : "rgba(244,241,234,0.44)";
            context.fillText(String(node.label).slice(0, 18), node.x + 8, node.y - 8);
          }
        });

        context.strokeStyle = "rgba(244,241,234,0.34)";
        context.strokeRect(18, 18, width - 36, height - 36);
        context.strokeStyle = "rgba(255,59,78,0.65)";
        context.beginPath();
        context.moveTo(width * 0.66, height * 0.24);
        context.lineTo(width * 0.81, height * 0.24);
        context.lineTo(width * 0.86, height * 0.31);
        context.stroke();

        if (!reduceMotion) raf = requestAnimationFrame(draw);
      };

      resize();
      draw();
      window.addEventListener("resize", resize);
      const tip = document.getElementById("model-atlas-graph-tip");

      const setActiveFromEvent = (event) => {
        const rect = canvas.getBoundingClientRect();
        const x = event.clientX - rect.left;
        const y = event.clientY - rect.top;
        let nearest = null;
        let nearestDist = 999;
        nodes.forEach((node) => {
          if (!node.href) return;
          const dist = Math.hypot(node.x - x, node.y - y);
          if (dist < nearestDist) {
            nearest = node;
            nearestDist = dist;
          }
        });
        activeNode = nearestDist < 26 ? nearest : null;
        canvas.style.cursor = activeNode ? "pointer" : "default";
        if (tip) {
          if (activeNode) {
            tip.hidden = false;
            tip.textContent = `${activeNode.type} / ${activeNode.label}`;
            tip.style.left = `${Math.min(rect.width - 220, Math.max(12, x + 14))}px`;
            tip.style.top = `${Math.min(rect.height - 48, Math.max(12, y + 14))}px`;
          } else {
            tip.hidden = true;
          }
        }
      };

      canvas.addEventListener("pointermove", (event) => {
        const rect = canvas.getBoundingClientRect();
        pointer = {
          x: (event.clientX - rect.left) / rect.width,
          y: (event.clientY - rect.top) / rect.height
        };
        setActiveFromEvent(event);
      });
      canvas.addEventListener("pointerleave", () => {
        activeNode = null;
        canvas.style.cursor = "default";
        if (tip) tip.hidden = true;
      });
      canvas.addEventListener("click", () => {
        if (activeNode?.href) window.location.href = activeNode.href;
      });
      document.addEventListener("astro:before-swap", () => cancelAnimationFrame(raf), { once: true });
    }
  </script>

