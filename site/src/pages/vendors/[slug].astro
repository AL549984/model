---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import SectionHeader from "../../components/sections/SectionHeader.astro";
import ModelCard from "../../components/cards/ModelCard.astro";
import RiskNotice from "../../components/data/RiskNotice.astro";
import SourceLinkBlock from "../../components/data/SourceLinkBlock.astro";
import ModelTimeline from "../../components/data/ModelTimeline.astro";
import { publicizeText } from "../../lib/publicCopy";
import vendors from "../../data/vendors.json";
import models from "../../data/models.json";

export function getStaticPaths() {
  return vendors.map((vendor) => ({ params: { slug: vendor.slug }, props: { vendor } }));
}

const { vendor } = Astro.props;
const vendorModels = models.filter((model) => model.vendorId === vendor.id);
const caseLibraryLabels: Record<string, string> = {
  usable: "可用",
  platform_only: "仅平台资料",
  thin: "证据偏薄"
};
const caseLibraryLabel = caseLibraryLabels[vendor.caseLibraryStatus] ?? vendor.caseLibraryStatus;
const timeline = [
  { date: "公开资料", title: "厂商路线已建档", summary: "整理厂商模型家族、代表模型和公开来源入口。" },
  { date: "模型状态", title: "模型条目已分级", summary: "代表模型按真实案例、待补公开案例或历史归档展示。" },
  { date: "案例库", title: "案例证据已检查", summary: "只有可核验公开 A 类案例可以进入精选。" }
];
---

<BaseLayout title={`${vendor.displayName} · Frontier Models Atlas`} description={`${vendor.displayName} 模型路线、代表模型、公开来源和案例覆盖状态。`}>
  <SectionHeader eyebrow="厂商详情" title={`${vendor.displayName} Model Atlas`} description={publicizeText(vendor.positioning)} />

  <div class="content-grid">
    <section class="page-grid">
      <div class="panel p-5">
        <h2 class="text-xl font-semibold">模型路线</h2>
        <div class="mt-4 grid gap-2 md:grid-cols-2">
          {vendor.families.map((family) => <div class="rounded-md border border-slate-700/70 bg-slate-950/40 px-3 py-2 text-sm text-slate-300">{family}</div>)}
        </div>
      </div>

      <div>
        <SectionHeader eyebrow="代表模型" title="当前网站条目" />
        <div class="grid gap-3 md:grid-cols-2">
          {vendorModels.length ? vendorModels.map((model) => <ModelCard model={model} compact />) : <p class="text-sm text-slate-400">暂无已接入模型页。</p>}
        </div>
      </div>

      <div>
        <SectionHeader eyebrow="时间线" title="公开资料状态" />
        <ModelTimeline items={timeline} />
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        <div class="panel p-4">
          <p class="font-semibold">优势</p>
          <ul class="mt-3 space-y-2 text-sm text-slate-300">
            {vendor.strengths.map((item) => <li>- {publicizeText(item)}</li>)}
          </ul>
        </div>
        <div class="panel p-4">
          <p class="font-semibold">不适合</p>
          <ul class="mt-3 space-y-2 text-sm text-slate-300">
            {vendor.risks.map((item) => <li>- {publicizeText(item)}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <aside class="page-grid">
      <RiskNotice title="案例库状态" tone={vendor.caseLibraryStatus === "usable" ? "neutral" : "limited"} notes={[`状态：${caseLibraryLabel}`, "不要把弱证据提升为 A 类案例。", "公开页面只展示可解释、可追溯的来源。"]} />
      <SourceLinkBlock sources={[vendor.officialSite]} />
      <div class="panel p-4">
        <p class="mono text-xs uppercase tracking-[0.14em] text-slate-300">资料状态</p>
        <p class="mt-2 text-sm text-slate-400">厂商来源、模型条目和案例库会持续更新。</p>
      </div>
    </aside>
  </div>
</BaseLayout>
