---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import SectionHeader from "../../components/sections/SectionHeader.astro";
import VendorCard from "../../components/cards/VendorCard.astro";
import TrustBoundary from "../../components/data/TrustBoundary.astro";
import vendors from "../../data/vendors.json";
import metrics from "../../data/metrics.json";
---

<BaseLayout title="厂商 · Model Atlas 模型图谱">
  <SectionHeader eyebrow="厂商地图" title="15 家 Canonical 厂商入口" description={`这里用于按厂商进入模型路线、代表模型和案例库状态。案例状态只表示当前公开证据覆盖，不代表厂商能力上限。`} />
  <div class="mb-5">
    <TrustBoundary title="厂商页怎么读" notes={[`覆盖 ${metrics.vendors} 家厂商、${metrics.models} 个模型。`, `当前 ${metrics.modelsWithCases} 个模型有 A 类案例，厂商页仍需继续补证。`, "多数厂商页仍是导航骨架和证据补全入口。"]} />
  </div>
  <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-3">
    {vendors.map((vendor) => <VendorCard vendor={vendor} />)}
  </div>
</BaseLayout>
